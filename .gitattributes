# Keep Unix line endings for everything that runs on the Linux server,
# so a Windows checkout never ships CRLF into shell/python/Docker files.
* text=auto eol=lf
*.sh   text eol=lf
*.py   text eol=lf
Dockerfile text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.toml text eol=lf

# Binary assets
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.mp4  binary
*.wav  binary
*.mp3  binary
*.webp binary
