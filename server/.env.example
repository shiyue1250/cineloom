# Cineloom remote generation server — environment.
# Copy to .env next to docker-compose.yml and adjust.

# API key required to call the server. Empty = open (trusted network only).
# Match this with the add-on's "Remote API Key" preference.
CINELOOM_API_KEY=

# Which physical GPU to pin to (host index, NVIDIA_VISIBLE_DEVICES).
CINELOOM_GPU=0

# Path to your downloaded LTX-2.3 model on the host (mounted read-only at /model).
CINELOOM_MODEL_DIR=/path/to/ltx23-distilled-int8

# Hard cap on frames per shot. 161 ≈ 6.7s@24; longer clips may exhaust VRAM.
CINELOOM_MAX_FRAMES=161

# Offload mode: "sequential" (~6-8 GB peak) or "model" (~10-15 GB, faster).
CINELOOM_OFFLOAD=sequential
